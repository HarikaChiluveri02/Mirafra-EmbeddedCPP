#include "main.h"
#include "FreeRTOS.h"
#include "task.h"

#define DWT_CTRL    (*(volatile uint32_t*)0xE0001000)

void vDriverAssistanceTask( void *pvParameters );
void vEmergencySystemTask( void *pvParameters );

TaskHandle_t xDriverHandle;
TaskHandle_t xEmergencyHandle;

static int driver_count = 0;
static int Emg_count    = 0;

typedef struct sensor
{
    bool  coll;
    float temp;
    int   door;
    bool  airbag;
} Sensor_status;

Sensor_status t1;

void SystemClock_Config(void);
static void MX_GPIO_Init(void);

int main(void)
{
    BaseType_t status;

    t1.coll   = false;
    t1.temp   = 50.00f;
    t1.door   = 0;
    t1.airbag = false;

    HAL_Init();
    SystemClock_Config();
    MX_GPIO_Init();

    status = xTaskCreate(vDriverAssistanceTask, "DriverAssistanceTask", 200, (void*)&t1, 3, &xDriverHandle);
    configASSERT(status == pdPASS);

    status = xTaskCreate(vEmergencySystemTask, "EmergencySystemTask", 200, (void*)&t1, 2, &xEmergencyHandle);
    configASSERT(status == pdPASS);

    vTaskStartScheduler();

    while (1) {}
}

void vDriverAssistanceTask(void *pvParameters)
{
    Sensor_status* sptr = (Sensor_status*)pvParameters;

    while(1)
    {
        // Normal driving - Green ON
        if(sptr->coll == false)
        {
            HAL_GPIO_WritePin(GPIOD, GPIO_PIN_12, GPIO_PIN_SET);   // Green ON
            HAL_GPIO_WritePin(GPIOD, GPIO_PIN_13, GPIO_PIN_RESET); // Orange OFF
        }

        // Simulate temperature rising
        sptr->temp += 0.5f;

        // Simulate door open at count 500, close at 800
        if(driver_count == 500)
            sptr->door = 1;   // door opens

        if(driver_count == 800)
            sptr->door = 0;   // door closes

        // Overheat warning → blink orange
        if(sptr->temp > 80.0f && sptr->coll == false)
        {
            HAL_GPIO_WritePin(GPIOD, GPIO_PIN_13, GPIO_PIN_SET);   // Orange ON
            vTaskDelay(pdMS_TO_TICKS(200));
            HAL_GPIO_WritePin(GPIOD, GPIO_PIN_13, GPIO_PIN_RESET); // Orange OFF
        }

        // Door open warning → blink blue
        if(sptr->door != 0)
        {
            HAL_GPIO_WritePin(GPIOD, GPIO_PIN_15, GPIO_PIN_SET);   // Blue ON
            vTaskDelay(pdMS_TO_TICKS(200));
            HAL_GPIO_WritePin(GPIOD, GPIO_PIN_15, GPIO_PIN_RESET); // Blue OFF
        }

        driver_count++;

        // Trigger collision after 2000 counts (~20 seconds)
        if(driver_count >= 2000 && sptr->coll == false)
        {
            sptr->coll = true;
        }

        // Stop green during collision
        if(sptr->coll == true)
        {
            HAL_GPIO_WritePin(GPIOD, GPIO_PIN_12, GPIO_PIN_RESET); // Green OFF
            HAL_GPIO_WritePin(GPIOD, GPIO_PIN_13, GPIO_PIN_RESET); // Orange OFF
            HAL_GPIO_WritePin(GPIOD, GPIO_PIN_15, GPIO_PIN_RESET); // Blue OFF
        }

        vTaskDelay(pdMS_TO_TICKS(10));
    }
}

void vEmergencySystemTask(void *pvParameters)
{
    Sensor_status* sptr = (Sensor_status*)pvParameters;

    while(1)
    {
        if(sptr->coll == true)
        {
            sptr->airbag = true;

            HAL_GPIO_WritePin(GPIOD, GPIO_PIN_14, GPIO_PIN_SET);   // Red ON
            vTaskDelay(pdMS_TO_TICKS(200));                        // emergency duration
            HAL_GPIO_WritePin(GPIOD, GPIO_PIN_14, GPIO_PIN_RESET); // Red OFF

            HAL_GPIO_WritePin(GPIOD, GPIO_PIN_13, GPIO_PIN_SET);   // Orange ON (recovery)
            vTaskDelay(pdMS_TO_TICKS(2000));                       // recovery duration
            HAL_GPIO_WritePin(GPIOD, GPIO_PIN_13, GPIO_PIN_RESET); // Orange OFF

            // Reset system back to normal driving
            sptr->airbag = false;
            sptr->coll   = false;
            sptr->temp   = 50.0f;  // reset temperature
            sptr->door   = 0;      // ensure door closed

            driver_count = 0;
            Emg_count    = 0;
        }

        vTaskDelay(pdMS_TO_TICKS(10));
    }
}

